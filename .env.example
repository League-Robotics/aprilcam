# AprilCam environment configuration — copy to .env and fill in values.
# This file is committed to the repo. .env is gitignored.

# Required: guards against sourcing the wrong environment.
JTL_APRILCAM=1

# Root directory for the project (default: directory containing .env).
# ROOT_DIR=/path/to/AprilTags

# Root directory for persistent state: cameras, calibrations, playfields.
# Auto-selected: FHS /var/lib/aprilcam (root/APRILCAM_SYSTEM=1) or XDG
# ~/.local/share/aprilcam (user). Override only when the default is wrong.
# APRILCAM_DATA_DIR=./data/aprilcam

# Directory for the daemon control socket, stream sockets, and pidfile.
# Auto-selected: FHS /run/aprilcam (root/APRILCAM_SYSTEM=1) or XDG
# $XDG_RUNTIME_DIR/aprilcam (user). Override only when the default is wrong.
# APRILCAM_SOCKET_DIR=/tmp/aprilcam

# Log directory for aprilcamd.log (default: FHS /var/log/aprilcam or XDG
# ~/.local/state/aprilcam). Override to redirect logs elsewhere.
# APRILCAM_LOG_DIR=/var/log/aprilcam

# Force FHS (1) or XDG (0) directory layout regardless of euid.
# Default ("auto"): FHS when euid == 0, XDG otherwise.
# Set to 1 when running under systemd DynamicUser= (not root, but needs FHS).
# APRILCAM_SYSTEM=

# Detection loop frame rate cap — frames per second (default: 10).
# Per-camera calibration.json "detection_fps" field overrides this value.
# APRILCAM_DETECTION_FPS=10

# Logging level for the daemon process (default: INFO).
# APRILCAM_LOG_LEVEL=INFO
